  "resultTypes": [
    {
      "typeId": "product_alchemist",
      "typeName": "产品炼金术师",
      "category": "商业服务",
      "coreTraits": [
        "用户思维强",
        "逻辑清晰",
        "协调能力强"
      ],
      "typicalProfile": "你是那种能把用户的模糊需求变成清晰方案的人。你享受从 0 到 1 设计产品的过程，也擅长平衡用户需求、技术可行性和商业价值。",
      "strengths": [
        {
          "title": "用户思维强，能洞察需求",
          "description": "你擅长站在用户角度思考问题，能快速理解用户的真实需求和痛点。",
          "example": "当用户说\"我想要一个更快的搜索\"，你能挖掘出背后真正的问题是\"找不到想要的内容\"，然后设计出智能推荐功能。"
        },
        {
          "title": "逻辑清晰，能拆解问题",
          "description": "你能把复杂的业务问题拆解成清晰的产品方案，让技术团队知道该做什么。",
          "example": "面对\"提升用户留存\"这个模糊目标，你能拆解成具体的功能点：新手引导优化、核心功能提醒、个性化推荐等，每个都有明确的数据指标。"
        },
        {
          "title": "协调能力强，能推动落地",
          "description": "你善于在不同团队之间沟通协调，推动产品从想法变成现实。",
          "example": "当技术说\"这个功能实现不了\"，运营说\"必须下周上线\"，你能找到平衡点：先做MVP版本快速验证，再根据数据决定是否投入更多资源。"
        }
      ],
      "weaknesses": [
        {
          "title": "容易陷入完美方案陷阱",
          "description": "有时候会过度追求完美的产品方案，导致上线时间延迟，错过最佳窗口期。",
          "improvements": [
            "学会先上线再优化的思维方式",
            "设定明确的时间节点，用MVP思维快速验证",
            "记住：完成比完美更重要"
          ]
        },
        {
          "title": "不太擅长处理感性问题",
          "description": "过于依赖数据和逻辑，在需要感性判断的场景（如品牌调性、情感化设计）可能不够敏感。",
          "improvements": [
            "多和设计师、运营同学交流，培养感性思维",
            "关注用户的情感反馈，不只是行为数据",
            "尝试用故事化的方式描述产品，而不只是功能列表"
          ]
        }
      ],
      "actionPlan": {
        "shortTerm": [
          {
            "step": "明确目标岗位",
            "details": "锁定产品经理、用户运营、数据分析师等岗位，研究这些岗位的具体要求和日常工作内容。"
          },
          {
            "step": "补齐技能短板",
            "details": "学习产品经理必备工具（Axure/Figma、SQL、数据分析），掌握PRD撰写、原型设计、数据分析等核心技能。"
          },
          {
            "step": "积累项目经验",
            "details": "参与1-2个实际项目（实习、校园项目、个人项目），完整经历需求分析→方案设计→落地验证的全流程。"
          }
        ],
        "midTerm": [
          {
            "step": "准备求职材料",
            "details": "用STAR法则描述项目经验，突出你如何发现问题、设计方案、推动落地、验证效果。准备作品集展示你的产品思维。"
          },
          {
            "step": "建立行业人脉",
            "details": "加入产品经理社群，参加行业活动，向前辈请教，了解不同公司的产品文化和工作方式。"
          }
        ]
      },
      "matchingConditions": {
